# .codex/config — OpenAI Codex CLI overlay
#
# Specializes AGENTS.md for Codex CLI.  Never relaxes GROUNDING.md.
# Shared context (build commands, conventions, scope boundary) lives in
# AGENTS.md.  This file adds only Codex CLI–specific settings.

[runtime]
approval_mode = "suggest"   # suggest | auto-edit | full-auto
model         = "<model-id>"
max_turns     = 40

[sandbox]
type        = "devcontainer"
network     = "deny"        # set to "allowlist" with [sandbox.allowlist]

[paths]
# See AGENTS.md §Scope Boundary for the canonical list.
write_allow = ["src/", "tests/", "docs/", ".agent/plan.md"]
write_deny  = ["secrets/", ".env*", "**/id_rsa*"]

[commands]
allow = ["pytest", "ruff", "mypy", "git diff", "git status"]
deny  = ["rm -rf", "git push --force", "npm publish"]

[telemetry]
session_log = ".agent/logs/"
